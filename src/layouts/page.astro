---
const { frontmatter } = Astro.props;
import Navbar from "../components/navbar.astro";
import "../global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>README // {frontmatter.title}</title>
  </head>
  <body>
    <Navbar />
    <main>
      <h1>{frontmatter.title}</h1>
      <slot />
    </main>
  </body>
</html>

<!-- Custom nutshell.js with the 'remove css classes' thing applied. Cus I need codeblocks from Prism -->
<script src="src/assets/nutshell.js" is:inline></script>
